BEGIN {
	FS = ","
	print "---------------------------------------"
	printf("%5s\t%-10s\t%s\n", "ID", "Name", "Revenue")
	print "---------------------------------------"
} 

$3 > 50 && $4 > 10000 {
	printf("%5d\t%-10s\t%.2f\n", $1, $2, $4)
	total += $4
} 

END {
	print "---------------------------------------"
	printf("Total Revenue Generated = %.2f\n", total)
	print "---------------------------------------"
}
